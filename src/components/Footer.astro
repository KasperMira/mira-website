---
import { getPath, type Locale } from "../data/i18n";
import { siteContent } from "../data/site-content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = siteContent[locale];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-3">
    <div class="space-y-3">
      <p class="text-lg font-semibold text-emerald-700">MIRA Software</p>
      <p class="text-sm text-slate-600">{content.footer.tagline}</p>
    </div>
    <div class="space-y-2 text-sm text-slate-600">
      <p class="font-semibold text-slate-900">Info</p>
      <p>{content.footer.company}</p>
      <a class="block text-emerald-700 hover:underline" href="mailto:sales@mirasoftware.be">sales@mirasoftware.be</a>
      <a class="block text-emerald-700 hover:underline" href="tel:+3252520749">+32 (0)52 52 07 49</a>
    </div>
    <div class="space-y-3 text-sm">
      <p class="font-semibold text-slate-900">{content.footer.newsletter}</p>
      <p class="text-slate-600">Mis nooit meer tips, webinars en updates over materiaalbeheer.</p>
      <a
        href={getPath(locale, "contact")}
        class="inline-flex rounded-lg bg-emerald-700 px-4 py-2 font-semibold text-white transition hover:bg-emerald-800"
      >
        Contact
      </a>
    </div>
  </div>
  <div class="border-t border-slate-200 py-4 text-center text-xs text-slate-500">{content.footer.copyright}</div>
</footer>
