---
import { getPath, type Locale, type PageKey } from "../data/i18n";
import { siteContent } from "../data/site-content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "./Sections/HeroSection.astro";
import ContentSections from "./Sections/ContentSections.astro";

interface Props {
  locale: Locale;
  pageKey: PageKey;
}

const { locale, pageKey } = Astro.props;
const page = siteContent[locale].pages[pageKey];
---

<BaseLayout locale={locale} pageKey={pageKey} title={page.seoTitle} description={page.seoDescription}>
  <HeroSection
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    subtitle={page.hero.subtitle}
    primaryLabel={page.hero.primaryLabel}
    secondaryLabel={page.hero.secondaryLabel}
    primaryHref={getPath(locale, "contact")}
    secondaryHref={getPath(locale, "aboutMira")}
  />
  <ContentSections sections={page.sections} />
</BaseLayout>
