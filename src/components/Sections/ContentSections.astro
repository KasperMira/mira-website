---
import type { Section } from "../../data/site-content";

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<div class="mx-auto max-w-6xl space-y-12 px-4 py-14 md:py-16">
  {sections.map((section) => {
    if (section.type === "text") {
      return (
        <section class="mira-shadow-card rounded-sm border border-slate-200 bg-white p-8 md:p-10">
          <h2 class="mira-section-title">{section.title}</h2>
          <div class="mt-5 space-y-3 text-slate-600">
            {section.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "cards") {
      return (
        <section>
          <h2 class="mira-section-title">{section.title}</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {section.items.map((item) => (
              <article class="mira-shadow-card rounded-sm border border-slate-200 bg-white p-6">
                <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-mira-red)] text-sm font-semibold text-white">
                  +
                </div>
                <h3 class="text-xl uppercase tracking-[0.03em] text-[var(--color-mira-charcoal)]">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
              </article>
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "quote") {
      return (
        <section class="relative overflow-hidden rounded-sm bg-[var(--color-mira-charcoal)] p-8 text-white md:p-10">
          <div class="absolute right-0 top-0 h-24 w-24 bg-[var(--color-mira-red)] opacity-80"></div>
          <p class="relative text-2xl leading-relaxed">"{section.quote}"</p>
          <p class="relative mt-5 text-sm font-semibold uppercase tracking-[0.08em] text-[var(--color-mira-yellow)]">{section.author}</p>
          <p class="relative mt-1 text-sm text-slate-200">{section.role}</p>
        </section>
      );
    }

    if (section.type === "list") {
      return (
        <section>
          <h2 class="mira-section-title">{section.title}</h2>
          <ul class="mt-6 grid gap-3 text-slate-600 md:grid-cols-2">
            {section.items.map((item) => (
              <li class="mira-shadow-card rounded-sm border border-slate-200 bg-white px-4 py-3">{item}</li>
            ))}
          </ul>
        </section>
      );
    }

    return (
      <section class="rounded-sm border border-slate-200 bg-white p-8 md:p-10">
        <h2 class="mira-section-title">{section.title}</h2>
        <p class="mt-4 text-slate-700">{section.body}</p>
        <a
          href={section.primaryHref}
          class="mt-6 inline-flex rounded-sm bg-[var(--color-mira-red)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-white transition hover:brightness-110"
        >
          {section.primaryLabel}
        </a>
      </section>
    );
  })}
</div>
