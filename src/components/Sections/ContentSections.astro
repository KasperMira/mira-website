---
import type { Section } from "../../data/site-content";

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<div class="mx-auto max-w-6xl space-y-12 px-4 py-14">
  {sections.map((section) => {
    if (section.type === "text") {
      return (
        <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">{section.title}</h2>
          <div class="mt-4 space-y-3 text-slate-600">
            {section.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "cards") {
      return (
        <section>
          <h2 class="text-2xl font-semibold text-slate-900">{section.title}</h2>
          <div class="mt-5 grid gap-4 md:grid-cols-2">
            {section.items.map((item) => (
              <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
                <p class="mt-2 text-sm text-slate-600">{item.body}</p>
              </article>
            ))}
          </div>
        </section>
      );
    }

    if (section.type === "quote") {
      return (
        <section class="rounded-2xl bg-emerald-700 p-8 text-white">
          <p class="text-xl leading-relaxed">{section.quote}</p>
          <p class="mt-5 font-semibold">{section.author}</p>
          <p class="text-sm text-emerald-100">{section.role}</p>
        </section>
      );
    }

    if (section.type === "list") {
      return (
        <section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">{section.title}</h2>
          <ul class="mt-4 grid gap-3 text-slate-600 md:grid-cols-2">
            {section.items.map((item) => (
              <li class="rounded-lg bg-slate-50 px-4 py-3">{item}</li>
            ))}
          </ul>
        </section>
      );
    }

    return (
      <section class="rounded-2xl border border-emerald-200 bg-emerald-50 p-8">
        <h2 class="text-2xl font-semibold text-slate-900">{section.title}</h2>
        <p class="mt-3 text-slate-700">{section.body}</p>
        <a
          href={section.primaryHref}
          class="mt-5 inline-flex rounded-lg bg-emerald-700 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-800"
        >
          {section.primaryLabel}
        </a>
      </section>
    );
  })}
</div>
