---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  secondaryLabel: string;
  primaryHref: string;
  secondaryHref: string;
}

const { eyebrow, title, subtitle, primaryLabel, secondaryLabel, primaryHref, secondaryHref } = Astro.props;
---

<section class="bg-gradient-to-b from-emerald-50 to-white">
  <div class="mx-auto max-w-6xl px-4 py-20">
    <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-emerald-700">{eyebrow}</p>
    <h1 class="max-w-4xl text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">{title}</h1>
    <p class="mt-6 max-w-3xl text-lg text-slate-600">{subtitle}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={primaryHref} class="rounded-lg bg-emerald-700 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-800">
        {primaryLabel}
      </a>
      <a href={secondaryHref} class="rounded-lg border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
