---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  secondaryLabel: string;
  primaryHref: string;
  secondaryHref: string;
}

const { eyebrow, title, subtitle, primaryLabel, secondaryLabel, primaryHref, secondaryHref } = Astro.props;
---

<section class="relative overflow-hidden bg-[var(--color-mira-charcoal)] text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,rgba(242,206,47,0.5),transparent_35%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(0,0,0,0.78),rgba(0,0,0,0.35))]"></div>
  <div class="relative mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-[1.1fr_0.9fr] md:py-20">
    <div>
      <p class="mb-4 inline-flex bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-mira-yellow)]">
        {eyebrow}
      </p>
      <h1 class="max-w-3xl text-4xl font-bold uppercase leading-tight tracking-[0.03em] text-white md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-2xl text-base text-slate-200 md:text-lg">{subtitle}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={primaryHref}
          class="rounded-sm bg-[var(--color-mira-red)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-white transition hover:brightness-110"
        >
          {primaryLabel}
        </a>
        <a
          href={secondaryHref}
          class="rounded-sm border border-white/50 px-6 py-3 text-sm font-semibold uppercase tracking-[0.08em] text-white transition hover:bg-white/10"
        >
          {secondaryLabel}
        </a>
      </div>
    </div>
    <div class="flex items-center justify-center">
      <div class="w-full max-w-md rounded-sm border border-white/15 bg-black/35 p-6 backdrop-blur-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-mira-yellow)]">Mira software</p>
        <p class="mt-4 text-sm leading-6 text-slate-200">
          Materiaalbeheer met sterke opvolging van gebruik, verbruik, reservatie, stock en onderhoud in een workflow die aansluit op
          de praktijk.
        </p>
      </div>
    </div>
  </div>
  <div class="mira-divider py-2 text-center">Materiaalbeheer eenvoudig en trefzeker</div>
</section>
