---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  secondaryLabel: string;
  primaryHref: string;
  secondaryHref: string;
}

const { eyebrow, title, subtitle, primaryLabel, secondaryLabel, primaryHref, secondaryHref } = Astro.props;
---

<section class="relative overflow-hidden bg-[var(--color-mira-charcoal)] text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,rgba(216,35,42,0.38),transparent_40%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_85%_90%,rgba(216,35,42,0.22),transparent_45%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(0,0,0,0.72),rgba(0,0,0,0.25))]"></div>
  <div class="pointer-events-none absolute inset-0 opacity-[0.06] [background-image:linear-gradient(rgba(255,255,255,0.4)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.4)_1px,transparent_1px)] [background-size:48px_48px]"></div>
  <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-20 md:grid-cols-[1.1fr_0.9fr] md:py-24">
    <div>
      <span class="mira-eyebrow mira-fade-up">{eyebrow}</span>
      <h1 class="mira-fade-up mira-fade-up-delay-1 max-w-3xl text-4xl font-bold uppercase leading-[1.05] tracking-[0.02em] text-white md:text-5xl">
        {title}
      </h1>
      <p class="mira-fade-up mira-fade-up-delay-2 mt-6 max-w-2xl text-base text-slate-200/90 md:text-lg">{subtitle}</p>
      <div class="mira-fade-up mira-fade-up-delay-3 mt-9 flex flex-wrap gap-3">
        <a href={primaryHref} class="mira-btn-primary">{primaryLabel}</a>
        <a href={secondaryHref} class="mira-btn-ghost">{secondaryLabel}</a>
      </div>
    </div>
    <div class="flex items-center justify-center">
      <div class="mira-fade-up mira-fade-up-delay-2 relative w-full max-w-md rounded-sm border border-white/15 bg-black/40 p-7 backdrop-blur-sm">
        <div class="absolute -left-[1px] top-6 h-10 w-1 bg-[var(--color-mira-red)]"></div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-mira-red)]">Mira software</p>
        <p class="mt-4 text-sm leading-6 text-slate-200">
          Materiaalbeheer met sterke opvolging van gebruik, verbruik, reservatie, stock en onderhoud in een workflow die aansluit op
          de praktijk.
        </p>
        <div class="mt-6 grid grid-cols-3 gap-3 border-t border-white/10 pt-5 text-center">
          <div>
            <p class="font-display text-2xl text-[var(--color-mira-red)]">20+</p>
            <p class="text-[0.65rem] uppercase tracking-[0.12em] text-slate-400">jaar</p>
          </div>
          <div>
            <p class="font-display text-2xl text-[var(--color-mira-red)]">1</p>
            <p class="text-[0.65rem] uppercase tracking-[0.12em] text-slate-400">overzicht</p>
          </div>
          <div>
            <p class="font-display text-2xl text-[var(--color-mira-red)]">∞</p>
            <p class="text-[0.65rem] uppercase tracking-[0.12em] text-slate-400">materiaal</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="relative h-1 bg-[linear-gradient(90deg,var(--color-mira-red)_0%,var(--color-mira-red)_60%,transparent_100%)]"></div>
  <div class="mira-divider text-center"><span class="mira-divider-text">Materiaalbeheer eenvoudig en trefzeker</span></div>
</section>
