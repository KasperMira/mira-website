---
import { Image } from "astro:assets";
import { getPath, type Locale } from "../../data/i18n";
import { homeCopy } from "../../data/home-copy";
import heroBg from "../../assets/images/hero-bg.jpg";
import softwareScreenshot from "../../assets/images/software-screenshot.jpg";
import appWorking from "../../assets/images/app-working.jpg";
import pcMira from "../../assets/images/pc-mira.jpg";
import videoThumb from "../../assets/images/video-thumb.jpg";
import logoJdn from "../../assets/images/logo-jdn.png";
import logoMediahuis from "../../assets/images/logo-mediahuis.png";
import logoSamoco from "../../assets/images/logo-samoco.png";
import sectorBouw from "../../assets/images/sector-bouw.jpg";
import sectorInstallatie from "../../assets/images/sector-installatie.jpg";
import sectorOverheid from "../../assets/images/sector-overheid.jpg";
import sectorMaritiem from "../../assets/images/sector-maritiem.jpg";
import sectorOnderwijs from "../../assets/images/sector-onderwijs.jpg";
import sectorAndere from "../../assets/images/sector-andere.jpg";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = homeCopy[locale];

const modulePages = ["moduleRegistration", "moduleReservation", "moduleStock", "moduleMaintenance"] as const;
const moduleItems = copy.modules.items.map((item, i) => ({ ...item, href: getPath(locale, modulePages[i]) }));

const sectorImages = [sectorBouw, sectorInstallatie, sectorOverheid, sectorMaritiem, sectorOnderwijs, sectorAndere];
const sectorItems = copy.sectors.items.map((title, i) => ({ title, image: sectorImages[i] }));

const testimonialMeta = [
  { logo: logoJdn, author: "Karel Maartens", role: "Logistiek Jan De Nul - A11" },
  { logo: logoMediahuis, author: "Walter Langmans", role: "Mediahuis" },
  { logo: logoSamoco, author: "Kjell Meire", role: "Samoco NV" }
];
const testimonials = testimonialMeta.map((t, i) => ({ ...t, quote: copy.testimonialQuotes[i] }));
---

<section class="relative overflow-hidden text-white">
  <Image
    src={heroBg}
    alt=""
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    format="avif"
    quality={70}
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div class="absolute inset-0 bg-[linear-gradient(115deg,rgba(0,0,0,0.82)_0%,rgba(0,0,0,0.55)_55%,rgba(0,0,0,0.35)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_85%_15%,rgba(216,35,42,0.22),transparent_45%)]"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-24 md:py-32">
    <span class="mira-eyebrow mira-fade-up">{copy.hero.eyebrow}</span>
    <h1 class="mira-fade-up mira-fade-up-delay-1 max-w-3xl text-4xl font-bold uppercase leading-[1.05] md:text-6xl">
      {copy.hero.titleBefore}<br /><span class="mira-title-accent text-[var(--color-mira-red)]">{copy.hero.titleAccent}</span> {copy.hero.titleAfter}
    </h1>
    <p class="mira-fade-up mira-fade-up-delay-2 mt-6 max-w-2xl text-base text-slate-100/90 md:text-lg">
      {copy.hero.paragraph}
    </p>
    <div class="mira-fade-up mira-fade-up-delay-3 mt-9 flex flex-wrap gap-3">
      <a href={getPath(locale, "contact")} class="mira-btn-primary">{copy.hero.primaryCta}</a>
      <a href={getPath(locale, "aboutMira")} class="mira-btn-ghost">{copy.hero.secondaryCta}</a>
    </div>
  </div>
  <div class="relative h-1 bg-[linear-gradient(90deg,var(--color-mira-red)_0%,var(--color-mira-red)_60%,transparent_100%)]"></div>
</section>

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <h2 class="mira-section-title">{copy.intro.title}</h2>
    <p class="mt-4 max-w-4xl text-slate-600">{copy.intro.paragraph}</p>
    <div class="mt-10 grid items-start gap-8 md:grid-cols-[0.95fr_1.05fr]">
      <div class="relative">
        <div class="absolute -left-3 -top-3 h-24 w-24 border-l-4 border-t-4 border-mira-red"></div>
        <div class="absolute -right-3 -bottom-3 h-24 w-24 border-r-4 border-b-4 border-mira-red"></div>
        <Image src={softwareScreenshot} alt={copy.intro.title} widths={[400, 640, 900]} sizes="(min-width: 768px) 45vw, 100vw" loading="lazy" decoding="async" class="mira-shadow-card relative w-full border border-slate-200" />
      </div>
      <div class="space-y-4 text-slate-700">
        <p>{copy.intro.longParagraph}</p>
        <div class="grid gap-4 sm:grid-cols-3">
          {copy.intro.features.map((feature) => (
            <article class="rounded-sm border border-slate-200 bg-slate-50 p-4">
              <h3 class="text-base uppercase text-[var(--color-mira-charcoal)]">{feature.title}</h3>
              <p class="mt-2 text-sm text-slate-600">{feature.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bg-[var(--color-mira-soft)]">
  <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <h2 class="mira-section-title">{copy.modules.title}</h2>
    <div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {moduleItems.map((item) => (
        <article class="mira-card mira-shadow-card rounded-sm p-6">
          <div class="mira-icon-badge mb-4 text-xl">+</div>
          <h3 class="text-xl uppercase text-[var(--color-mira-charcoal)]">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
          <a class="mt-5 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-mira-red)] transition hover:gap-2" href={item.href}>{copy.modules.linkLabel} <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="mira-divider text-center"><span class="mira-divider-text">{copy.dividerMaterial}</span></section>

<section class="bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1.2fr_0.8fr] md:py-16">
    <div>
      <h2 class="mira-section-title">{copy.thinking.title}</h2>
      <p class="mt-5 text-slate-700">{copy.thinking.body}</p>
      <a href={getPath(locale, "aboutMira")} class="mt-6 inline-flex rounded-sm bg-[var(--color-mira-red)] px-6 py-3 text-xs font-semibold uppercase tracking-[0.08em] text-white">
        {copy.thinking.cta}
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-1">
      <Image src={appWorking} alt="" widths={[320, 500, 700]} sizes="(min-width: 768px) 30vw, 50vw" loading="lazy" decoding="async" class="mira-shadow-card w-full border border-slate-200 object-cover" />
    </div>
  </div>
</section>

<section class="mira-divider text-center"><span class="mira-divider-text">{copy.dividerCanAlso}</span></section>

<section class="bg-[var(--color-mira-soft)]">
  <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <h2 class="mira-section-title">{copy.video.title}</h2>
    <p class="mt-4 max-w-3xl text-slate-700">{copy.video.paragraph}</p>
    <a href="https://www.youtube.com/watch?v=94YJrvXbbFA" class="mt-7 block max-w-3xl">
      <div class="relative overflow-hidden border border-slate-300">
        <Image src={videoThumb} alt="MIRA software video" widths={[480, 720, 960]} sizes="(min-width: 768px) 768px, 100vw" loading="lazy" decoding="async" class="h-full w-full object-cover" />
        <div class="absolute inset-0 grid place-items-center bg-black/30 text-6xl text-white">▶</div>
      </div>
    </a>
  </div>
</section>

<section class="mira-divider text-center"><span class="mira-divider-text">{copy.dividerSectors}</span></section>

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <div class="grid gap-4 md:grid-cols-3">
      {testimonials.map((item) => (
        <article class="mira-card mira-shadow-card rounded-sm p-7">
          <div class="flex items-start justify-between">
            <Image src={item.logo} alt={item.role} height={56} loading="lazy" decoding="async" class="h-14 w-auto object-contain" />
            <span class="font-display text-5xl leading-none text-mira-red">&#8220;</span>
          </div>
          <p class="mt-4 text-sm leading-6 text-slate-700">{item.quote}</p>
          <div class="mt-5 border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-[var(--color-mira-red)]">{item.author}</p>
            <p class="text-xs text-slate-500">{item.role}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="bg-[var(--color-mira-soft)]">
  <div class="mx-auto max-w-6xl px-4 py-14 md:py-16">
    <h2 class="mira-section-title">{copy.sectors.title}</h2>
    <p class="mt-4 max-w-4xl text-slate-700">{copy.sectors.paragraph}</p>
    <div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sectorItems.map((sector) => (
        <article class="mira-tile">
          <Image src={sector.image} alt={sector.title} widths={[320, 480, 640]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" loading="lazy" decoding="async" class="h-52 w-full object-cover" />
          <p class="mira-tile-label"><span>{sector.title}</span></p>
        </article>
      ))}
    </div>
  </div>
</section>
