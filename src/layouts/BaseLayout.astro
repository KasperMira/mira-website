---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import "../styles/global.css";
import { getPath, locales, type Locale, type PageKey } from "../data/i18n";

interface Props {
  locale: Locale;
  pageKey: PageKey;
  title: string;
  description: string;
}

const { locale, pageKey, title, description } = Astro.props;
const siteUrl = Astro.site ?? new URL("https://kaspermira.github.io");
const rawBasePath = import.meta.env.BASE_URL || "/";
const basePath = rawBasePath.endsWith("/") ? rawBasePath : `${rawBasePath}/`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const alternateLinks = locales.map((targetLocale) => ({
  hrefLang: targetLocale,
  href: new URL(getPath(targetLocale, pageKey), siteUrl).toString()
}));
const defaultHref = new URL(getPath("nl", pageKey), siteUrl).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.hrefLang} href={link.href} />)}
    <link rel="alternate" hreflang="x-default" href={defaultHref} />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="icon" href={`${basePath}favicon.ico`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MIRA Software" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:locale" content={locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[var(--color-mira-soft)] text-slate-900">
    <Header locale={locale} pageKey={pageKey} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <CookieBanner locale={locale} />
  </body>
</html>
